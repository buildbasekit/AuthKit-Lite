        {
          "name": "Auth | Logout [POST]",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.environment.unset(\"access_token\"); \r",
                  "pm.environment.unset(\"refresh_token\");"
                ],
                "type": "text/javascript",
                "packages": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
